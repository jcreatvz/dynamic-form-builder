{
  "title": "Project Inquiry",
  "description": "Tell us what you need and we will follow up with the next best step.",
  "submitText": "Send Inquiry",
  "theme": {
    "accentColor": "#2563eb",
    "layout": "single",
    "colorMode": "dark"
  },
  "submission": {
    "type": "googleSheets",
    "googleEndpoint": "https://script.google.com/macros/s/AKfycbxEsgD-PteNwp7duQn-CrZHZ5dLd3D19gNVYxZYLROa7Slv0CHBi4GYEnEOGPHQukxysQ/exec"
  },
  "fields": [
    {
      "id": "full_name",
      "type": "text",
      "label": "Full Name",
      "placeholder": "Jane Smith",
      "helper": "",
      "required": true
    },
    {
      "id": "email",
      "type": "email",
      "label": "Email",
      "placeholder": "jane@example.com",
      "helper": "",
      "required": true
    },
    {
      "id": "service",
      "type": "select",
      "label": "Service Needed",
      "placeholder": "Choose one",
      "helper": "",
      "required": true,
      "options": [
        "Website",
        "Automation",
        "Branding"
      ],
      "display": "dropdown"
    },
    {
      "id": "details",
      "type": "textarea",
      "label": "Project Details",
      "placeholder": "Share goals, timeline, and anything else we should know.",
      "helper": "",
      "required": false
    },
    {
      "id": "email_2",
      "type": "email",
      "label": "Email",
      "placeholder": "",
      "helper": "",
      "required": false
    },
    {
      "id": "dropdown",
      "type": "select",
      "label": "Dropdown",
      "placeholder": "Choose one",
      "helper": "",
      "required": false,
      "options": [
        "Option 1",
        "Option 2"
      ],
      "display": "dropdown"
    }
  ]
}
