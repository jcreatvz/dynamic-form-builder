{
  "title": "Project Inquiry",
  "description": "Tell us what you need and we will follow up with the next best step.",
  "submitText": "SUBMIT",
  "theme": {
    "accentColor": "#2563eb",
    "layout": "single",
    "colorMode": "dark",
    "bodyBackgroundImage": "",
    "formBackgroundImage": "",
    "formBackgroundOpacity": 0.15,
    "heroMedia": {
      "type": "video",
      "url": "https://www.youtube.com/watch?v=5URefVYaJrA"
    }
  },
  "submission": {
    "type": "googleSheets",
    "googleEndpoint": "https://script.google.com/macros/s/AKfycbz825bb8xYwjdYuTkFlAiPd2_DApICs_dOcLnLHiO3DmioSlLFEEKQ902i_6y4U7dKieg/exec"
  },
  "fields": [
    {
      "id": "full_name",
      "type": "text",
      "label": "Full Name",
      "placeholder": "Jane Smith",
      "helper": "",
      "required": true,
      "visibility": {
        "defaultState": "hidden",
        "action": "show",
        "fieldId": "service",
        "operator": "equals",
        "value": "Branding"
      }
    },
    {
      "id": "email",
      "type": "email",
      "label": "Email",
      "placeholder": "jane@example.com",
      "helper": "",
      "required": true
    },
    {
      "id": "service",
      "type": "select",
      "label": "Service Needed",
      "placeholder": "Choose one",
      "helper": "",
      "required": true,
      "options": [
        "Website",
        "Automation",
        "Branding"
      ],
      "optionRulesText": "",
      "optionRules": [],
      "display": "dropdown"
    },
    {
      "id": "details",
      "type": "textarea",
      "label": "Project Details",
      "placeholder": "Share goals, timeline, and anything else we should know.",
      "helper": "",
      "required": false
    },
    {
      "id": "email_2",
      "type": "email",
      "label": "Email",
      "placeholder": "",
      "helper": "",
      "required": false
    },
    {
      "id": "dropdown",
      "type": "select",
      "label": "Dropdown",
      "placeholder": "Choose one",
      "helper": "",
      "required": false,
      "options": [
        "Option 1"
      ],
      "optionRulesText": "when service = Website:\n  Landing Page\n  E-commerce\nwhen service = Automation:\n  Zapier\n  Custom API\ndefault:\n  General Inquiry",
      "optionRules": [
        {
          "sourceFieldId": "service",
          "operator": "equals",
          "value": "Website",
          "options": [
            "Landing Page",
            "E-commerce"
          ]
        },
        {
          "sourceFieldId": "service",
          "operator": "equals",
          "value": "Automation",
          "options": [
            "Zapier",
            "Custom API"
          ]
        },
        {
          "sourceFieldId": "",
          "operator": "default",
          "value": "",
          "options": [
            "General Inquiry"
          ]
        }
      ],
      "display": "dropdown"
    },
    {
      "id": "section",
      "type": "section",
      "label": "Section Title",
      "placeholder": "",
      "helper": "Optional section description.",
      "required": false
    }
  ]
}
